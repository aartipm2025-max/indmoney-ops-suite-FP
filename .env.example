# ──────────────────────────────────────────────────────────────────
# INDmoney Investor Ops & Intelligence Suite — Environment Template
# Copy to .env and fill in your values.  Never commit .env to git.
# ──────────────────────────────────────────────────────────────────

# Application
APP_NAME=INDmoney Investor Ops Suite
APP_ENV=dev                        # dev | staging | prod
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR

# ── LLM: Groq (REQUIRED) ─────────────────────────────────────────
# Get your free API key at https://console.groq.com/
GROQ_API_KEY=paste_your_key_here
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile   # complex reasoning, pulse generation
GROQ_MODEL_FAST=llama-3.1-8b-instant         # routing, theme extraction, LLM judge

# ── LLM: Gemini (OPTIONAL fallback) ──────────────────────────────
# Leave blank to use Groq only.  Get key at https://ai.google.dev/
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# ── Embedding & Reranking (downloaded automatically on first run) ─
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Storage Paths ─────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
STATE_DB_PATH=./data/state.db

# ── RAG Parameters ────────────────────────────────────────────────
RAG_TOP_K=10          # candidates retrieved before reranking
RAG_RERANK_K=3        # top chunks passed to LLM after reranking

# ── LLM Reliability ───────────────────────────────────────────────
LLM_MAX_RETRIES=3                  # tenacity retry attempts per call
LLM_CIRCUIT_BREAKER_THRESHOLD=5    # failures before circuit opens
LLM_CIRCUIT_BREAKER_WINDOW_S=60    # failure counting window (seconds)
